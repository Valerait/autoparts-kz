# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/autoparts?schema=public"

# =============================================================================
# AUTH
# =============================================================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
OTP_EXPIRES_MINUTES=5
OTP_MAX_ATTEMPTS=3

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL="redis://localhost:6379"

# =============================================================================
# WHATSAPP PROVIDER
# =============================================================================
# Provider: mock | twilio | meta_cloud | 360dialog
WHATSAPP_PROVIDER="mock"
# Twilio
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM=""
# Meta WhatsApp Cloud API
META_WHATSAPP_TOKEN=""
META_WHATSAPP_PHONE_ID=""
# 360dialog
DIALOG360_API_KEY=""
DIALOG360_API_URL=""

# =============================================================================
# S3 FILE STORAGE
# =============================================================================
S3_ENDPOINT=""
S3_BUCKET="autoparts"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="us-east-1"
S3_PUBLIC_URL=""

# =============================================================================
# APP
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="АвтоЗапчасти"
NEXT_PUBLIC_WHATSAPP_NUMBER="+79001234567"

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
OTP_RATE_LIMIT_WINDOW_MS=300000
OTP_RATE_LIMIT_MAX_REQUESTS=5
