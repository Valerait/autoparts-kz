// =============================================================================
// AUTO PARTS STORE - DATABASE SCHEMA
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// USERS & AUTH
// =============================================================================

enum UserRole {
  CUSTOMER
  MANAGER
  ADMIN
}

enum AuthProvider {
  LOCAL
  WHATSAPP
}

model User {
  id            String       @id @default(cuid())
  phone         String       @unique
  passwordHash  String?
  name          String?
  email         String?
  role          UserRole     @default(CUSTOMER)
  provider      AuthProvider @default(LOCAL)
  phoneVerified Boolean      @default(false)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  orders         Order[]
  cartItems      CartItem[]
  favorites      Favorite[]
  savedVehicles  UserVehicle[]
  refreshTokens  RefreshToken[]
  otpCodes       OtpCode[]
  auditLogs      AuditLog[]

  @@index([phone])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone, code])
  @@index([phone, createdAt])
}

// =============================================================================
// CATALOG
// =============================================================================

model Brand {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  logo        String?
  description String?
  metaTitle   String?
  metaDesc    String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products Product[]

  @@index([slug])
  @@index([isActive])
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  image       String?
  description String?
  metaTitle   String?
  metaDesc    String?
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  products Product[]

  @@index([slug])
  @@index([parentId])
  @@index([isActive])
}

model Product {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  sku              String   @unique
  brandId          String
  brand            Brand    @relation(fields: [brandId], references: [id])
  categoryId       String
  category         Category @relation(fields: [categoryId], references: [id])
  description      String?
  shortDescription String?
  price            Decimal? @db.Decimal(12, 2)
  comparePrice     Decimal? @db.Decimal(12, 2)
  costPrice        Decimal? @db.Decimal(12, 2)
  quantity         Int      @default(0)
  unit             String   @default("шт")
  weight           Decimal? @db.Decimal(8, 3)
  isActive         Boolean  @default(true)
  isOnOrder        Boolean  @default(false) // "под заказ"
  metaTitle        String?
  metaDesc         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Catalog numbers
  catalogNumbers  CatalogNumber[]
  images          ProductImage[]
  attributes      ProductAttribute[]
  vehicleApps     VehicleApplication[]
  // Analogues: this product's analogues
  analoguesOf     ProductAnalogue[] @relation("OriginalProduct")
  analogues       ProductAnalogue[] @relation("AnalogueProduct")
  // Warehouse
  warehouseStock  WarehouseStock[]

  cartItems  CartItem[]
  orderItems OrderItem[]
  favorites  Favorite[]

  @@index([slug])
  @@index([sku])
  @@index([brandId])
  @@index([categoryId])
  @@index([isActive])
  @@index([name])
}

model CatalogNumber {
  id               String  @id @default(cuid())
  productId        String
  product          Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  originalNumber   String  // Original as-is
  normalizedNumber String  // Cleaned: no spaces, dashes, uppercase
  numberType       String  @default("OEM") // OEM, CROSS, ALIAS, SKU
  brandName        String? // Brand this number belongs to

  @@index([normalizedNumber])
  @@index([productId])
  @@index([originalNumber])
  // Trigram index created in migration
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)

  @@index([productId])
}

model ProductAttribute {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  value     String

  @@index([productId])
}

model ProductAnalogue {
  id               String  @id @default(cuid())
  originalId       String
  original         Product @relation("OriginalProduct", fields: [originalId], references: [id], onDelete: Cascade)
  analogueId       String
  analogue         Product @relation("AnalogueProduct", fields: [analogueId], references: [id], onDelete: Cascade)
  analogueType     String  @default("ANALOGUE") // ANALOGUE, REPLACEMENT, SUBSTITUTE

  @@unique([originalId, analogueId])
  @@index([originalId])
  @@index([analogueId])
}

// =============================================================================
// VEHICLES
// =============================================================================

model VehicleMake {
  id     String         @id @default(cuid())
  name   String         @unique
  slug   String         @unique
  models VehicleModel[]

  @@index([slug])
}

model VehicleModel {
  id     String         @id @default(cuid())
  name   String
  slug   String
  makeId String
  make   VehicleMake    @relation(fields: [makeId], references: [id], onDelete: Cascade)
  years  VehicleYear[]

  @@unique([makeId, slug])
  @@index([makeId])
}

model VehicleYear {
  id      String              @id @default(cuid())
  year    Int
  modelId String
  model   VehicleModel        @relation(fields: [modelId], references: [id], onDelete: Cascade)
  apps    VehicleApplication[]

  @@unique([modelId, year])
  @@index([modelId])
}

model VehicleApplication {
  id            String      @id @default(cuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  vehicleYearId String
  vehicleYear   VehicleYear @relation(fields: [vehicleYearId], references: [id], onDelete: Cascade)
  notes         String?

  @@unique([productId, vehicleYearId])
  @@index([productId])
  @@index([vehicleYearId])
}

model UserVehicle {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  make    String
  model   String
  year    Int
  vin     String?

  @@index([userId])
}

// =============================================================================
// WAREHOUSE
// =============================================================================

model Warehouse {
  id       String           @id @default(cuid())
  name     String
  address  String?
  isActive Boolean          @default(true)
  stocks   WarehouseStock[]
}

model WarehouseStock {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  quantity    Int       @default(0)
  updatedAt   DateTime  @updatedAt

  @@unique([productId, warehouseId])
  @@index([productId])
}

// =============================================================================
// CART & ORDERS
// =============================================================================

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([userId])
}

enum OrderStatus {
  NEW
  PROCESSING
  CONFIRMED
  SHIPPED
  COMPLETED
  CANCELLED
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  status          OrderStatus @default(NEW)
  totalAmount     Decimal     @db.Decimal(12, 2)
  customerName    String
  customerPhone   String
  customerEmail   String?
  deliveryAddress String?
  comment         String?
  contactMethod   String      @default("phone") // phone, whatsapp, email
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items       OrderItem[]
  statusLogs  OrderStatusLog[]

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@index([createdAt])
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  quantity   Int
  price      Decimal @db.Decimal(12, 2)
  name       String  // Snapshot of product name at time of order
  sku        String  // Snapshot of SKU

  @@index([orderId])
}

model OrderStatusLog {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus OrderStatus?
  toStatus  OrderStatus
  comment   String?
  changedBy String?
  createdAt DateTime    @default(now())

  @@index([orderId])
}

// =============================================================================
// FAVORITES
// =============================================================================

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// =============================================================================
// CMS / BANNERS
// =============================================================================

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  image     String
  link      String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =============================================================================
// IMPORT LOG
// =============================================================================

model ImportLog {
  id          String   @id @default(cuid())
  fileName    String
  totalRows   Int      @default(0)
  successRows Int      @default(0)
  errorRows   Int      @default(0)
  errors      Json?    // Array of {row, field, message}
  status      String   @default("pending") // pending, processing, completed, failed
  startedBy   String?
  createdAt   DateTime @default(now())
  completedAt DateTime?
}

// =============================================================================
// AUDIT LOG
// =============================================================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  details   Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}
